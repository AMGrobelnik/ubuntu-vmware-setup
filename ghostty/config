# Ghostty Terminal Configuration
# Set fish as default shell
shell-integration = fish
command = /usr/bin/fish

# Theme
theme = catppuccin-mocha.conf

# Optional: Some nice defaults
font-family = monospace
font-size = 12
window-padding-x = 2
window-padding-y = 2

# Tab bar position
gtk-tabs-location = bottom

# Focus follows mouse
focus-follows-mouse = true

# Scrollback buffer (number of lines to keep in history)
# Default: 10,000,000 (10MB) | Max: 4,294,967,295 (~4GB)
# Set to 1GB for extensive scrollback history
scrollback-limit = 1000000000

# Disable dimming of unfocused splits/windows
unfocused-split-opacity = 1.0
keybind = shift+enter=text:\x1b\r
clipboard-paste-protection = false

# Windows-style copy/paste: ctrl+c copies if there's a selection, else falls through to SIGINT
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard

# Highlight auto-copies to system clipboard; right-click pastes
copy-on-select = clipboard
right-click-action = paste
